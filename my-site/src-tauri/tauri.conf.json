{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "bluearchive-info-desktop",
  "version": "0.1.1",
  "identifier": "io.github.dhlee515.bluearchive-info",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Blue Archive Info",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://schaledb.com; img-src 'self' https: data: blob:; media-src 'self' https: blob:; frame-src https://www.youtube.com https://www.youtube-nocookie.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../tools/ocr/extract_inventory.py": "tools/ocr/extract_inventory.py",
      "../tools/ocr/remap.json": "tools/ocr/remap.json",
      "../tools/ocr/icon_hashes.json": "tools/ocr/icon_hashes.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/dhlee515/blue_archive_info/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUyNUM5QjE4QzA1NEZFOUIKUldTYi9sVEFHSnRjNHU4cEhkeTE1SkFENjk4QS9JL1prME5vSnc1MnAwRWpxY1ExL2d0UThWUFEK"
    }
  }
}
